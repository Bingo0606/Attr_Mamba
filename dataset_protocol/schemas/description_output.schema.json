{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generated referring descriptions",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["file_id", "sentence"],
    "additionalProperties": false,
    "properties": {
      "file_id": {
        "type": ["string", "integer"]
      },
      "sentence": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

